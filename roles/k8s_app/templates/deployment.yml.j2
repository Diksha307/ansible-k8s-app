apiVersion: apps/v1
kind: Deployment

metadata:
  name: {{ app_name }}
  namespace: {{ namespace_name }}

spec:
  replicas: {{ replica_count }}

  selector:
    matchLabels:
      app: {{ app_name }}

  strategy:
    type: RollingUpdate
    rollingUpdate:
      maxSurge: 1
      maxUnavailable: 0

  template:
    metadata:
      labels:
        app: {{ app_name }}

    spec:

      containers:

      - name: fastapi

        image: {{ image_name }}

        ports:
        - containerPort: {{ container_port }}

        envFrom:
        - configMapRef:
            name: {{ app_name }}-config

      - name: redis

        image: redis:7

        ports:
        - containerPort: 6379
